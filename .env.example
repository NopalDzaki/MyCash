# Telegram Bot Token (dapatkan dari @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Google Sheets Configuration
# Spreadsheet ID dari URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account Credentials
# Download JSON key file dari Google Cloud Console → Service Accounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Timezone Configuration (default: Asia/Jakarta)
APP_TZ=Asia/Jakarta

